        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"statements\": [\n    {\n      \"statement\": \"CREATE (c:Chunk {id: $id, text: $text, embedding: $embedding})\",\n      \"parameters\": {\n        \"id\": \"{{ $json.id }}\",\n        \"text\": \"{{ $json.text }}\",\n        \"embedding\": {{ JSON.stringify($json.embedding) }}\n      }\n    }\n  ]\n}",
