    {
      "parameters": {
        "jsCode": "const sampleChunks = $('Sample Chunks').all();\n\nreturn sampleChunks.map((chunk, index) => {\n  const embeddingItem = $('Ollama Embed').all()[index];\n  return {\n    json: {\n      id: chunk.json.id,\n      text: chunk.json.text,\n      embedding: embeddingItem.json.embedding\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
