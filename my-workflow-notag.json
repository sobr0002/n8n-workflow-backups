      "id": "bb24e231-4c7a-4084-a17d-02ee06117f14",
      "name": "Merge Data"
    },
    {
      "parameters": {
        "jsCode": "const chunks = [\n  \"Neo4j is a graph database that stores data as nodes and relationships.\",\n  \"Vector embeddings represent text as numerical arrays for semantic search.\",\n  \"RAG combines retrieval from a database with text generation from an LLM.\",\n  \"Ollama allows you to run large language models locally on your machine.\",\n  \"n8n is a workflow automation tool that connects different services together.\"\n];\n\nreturn chunks.map((text, index) => ({\n  json: {\n    id: index,\n    text: text\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
