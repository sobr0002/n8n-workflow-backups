    {
      "parameters": {
        "jsCode": "const data = JSON.parse($input.first().json.data); // Henter 873 øvelser, konverterer fra String til JSON\n\n// Tag kun den første øvelse til test\n//const testData = [data[0]];\n\nconst chunks = []; // Tom liste\n\nfor (const exercise of data) { // Splitter hver sætning til chunk, som indekseres \n  exercise.instructions.forEach((sentence, index) => {\n    chunks.push({\n      json: {\n        exerciseId: exercise.id || exercise.name,\n        exerciseName: exercise.name,\n        chunkIndex: index,\n        text: sentence\n      }\n    });\n  });\n}\n\nreturn chunks;"
      },
