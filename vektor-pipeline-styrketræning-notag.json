    {
      "parameters": {
        "jsCode": "/**\n * \nconst embedding = $input.first().json.embedding;\nconst chunkData = $('Chunk instructioner').item.json;\n\nreturn [{\n  json: {\n    exerciseId: chunkData.exerciseId,\n    exerciseName: chunkData.exerciseName,\n    chunkIndex: chunkData.chunkIndex,\n    text: chunkData.text,\n    embedding: embedding\n  }\n}]; */\nconst embedding = $input.first().json.embedding;\nconst chunkData = $('Send 1 chunk ad gangen').item.json;\n\nreturn [{\n  json: {\n    exerciseId: chunkData.exerciseId,\n    exerciseName: chunkData.exerciseName,\n    chunkIndex: chunkData.chunkIndex,\n    text: chunkData.text,\n    embedding: embedding\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
        16
      ],
      "id": "1a8388f1-17cf-4f20-9145-43a28a593be7",
      "name": "Konverter embedding til tal-array for vektor-søgning"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nreturn [{\n  json: {\n    statements: [{\n      statement: \"MERGE (c:ØvelseChunk {exerciseId: $exerciseId, chunkIndex: $chunkIndex}) SET c.text = $text, c.embedding = $embedding, c.exerciseName = $exerciseName\",\n      parameters: {\n        exerciseId: data.exerciseId,\n        exerciseName: data.exerciseName,\n        chunkIndex: data.chunkIndex,\n        text: data.text,\n        embedding: data.embedding\n      }\n    }]\n  }\n}];"
      },
