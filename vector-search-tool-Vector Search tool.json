        "body": "={{ JSON.stringify({   statements: [{     statement: `       CALL db.index.vector.queryNodes('exercise_chunk_index', 5, $embedding)       YIELD node, score       MATCH (e:Øvelse)-[:HAR_CHUNK]->(node)       RETURN e.navn AS navn, node.text AS tekst, score       ORDER BY score DESC     `,     parameters: {       embedding: $json.embedding     }   }] }) }}",
