        "httpBasicAuth": {
          "id": "pZ6fSL57NtM11zzy",
          "name": "neo4j"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const results = $input.first().json.results[0].data;\n\nconst øvelser = results.map(row => \n  `${row.row[0]}: ${row.row[1]} (score: ${row.row[2].toFixed(2)})`\n).join('\\n');\n\nreturn [{ json: { response: øvelser } }];"
      },
